# Port the simulator listens on (Render injects PORT in production)
PORT="4001"

# Base URL of the CRM that receives receipt webhooks and conversion orders
CRM_URL="http://localhost:3000"

# Shared HMAC secret — must match the CRM's WEBHOOK_SECRET
WEBHOOK_SECRET="dev-webhook-secret-change-me"

# Lifecycle speed multiplier (4 = full funnel plays out ~4x faster for demos)
SIM_SPEED="1"
