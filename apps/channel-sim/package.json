{
  "name": "@resonate/channel-sim",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --target node20 --clean",
    "build:vercel": "esbuild src/serverless.ts --bundle --platform=node --format=esm --target=node22 --external:express --external:zod --external:@vercel/functions --outfile=api/index.js",
    "vercel-build": "pnpm build:vercel",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@resonate/shared": "workspace:*",
    "@vercel/functions": "^2.2.13",
    "express": "^5.1.0",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^20",
    "esbuild": "^0.25.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.0",
    "typescript": "^5"
  }
}
