{
  "name": "resonate",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "concurrently -n crm,sim,warm -c blue,magenta,green \"pnpm --filter @resonate/crm dev\" \"pnpm --filter @resonate/channel-sim dev\" \"node scripts/warm-dev.mjs\"",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @resonate/crm db:generate",
    "db:migrate": "pnpm --filter @resonate/crm db:migrate",
    "db:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "packageManager": "pnpm@11.5.3",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@prisma/client": "^6.16.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.5.0",
    "concurrently": "^10.0.3",
    "playwright-core": "^1.60.0",
    "prisma": "^6.16.0",
    "tsx": "^4.20.0"
  }
}
